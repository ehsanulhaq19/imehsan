# Copy to .env and adjust. Do not commit real secrets.

POSTGRES_USER=imehsan
POSTGRES_PASSWORD=imehsan
POSTGRES_DB=imehsan
POSTGRES_PORT=5432

BACKEND_PORT=3001
FRONTEND_PORT=3000

# Local dev: backend on 3001; browser calls API (use host-accessible URL if needed)
NEXT_PUBLIC_API_URL=http://localhost:3001

JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

GROK_API_KEY=

# Single connection string (used by Nest + migration CLI)
DATABASE_URL=postgres://imehsan:imehsan@localhost:5432/imehsan

# Public site origin for share links (vlogs); match your Next.js URL
SITE_PUBLIC_URL=http://localhost:3000
