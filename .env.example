# Copy to .env and adjust. Do not commit real secrets.
#
# Layout matches docker-compose.yml: one section per service, then host-only vars.

# =============================================================================
# postgres — container env + published DB port (service: postgres)
# =============================================================================
POSTGRES_USER=imehsan
POSTGRES_PASSWORD=imehsan
POSTGRES_DB=imehsan
POSTGRES_PORT=5432

# =============================================================================
# backend — container env (service: backend)
# =============================================================================
# Host port : container listen port (container must match Dockerfile EXPOSE / Nest PORT)
BACKEND_PORT=3001
PORT=3001

NODE_ENV=production

# Built by compose as postgres://USER:PASSWORD@postgres:5432/DB — use DATABASE_URL below on the host only.
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d
GROK_API_KEY=
UPLOAD_DIR=/app/uploads
# Local dev: http://localhost:3000 — production behind nginx: https://your-domain.com
SITE_PUBLIC_URL=http://localhost:3000

# Nest + TypeORM CLI on your machine (localhost, not the in-compose URL above)
DATABASE_URL=postgres://imehsan:imehsan@localhost:5432/imehsan

# =============================================================================
# frontend — container env + published app port (service: frontend)
# =============================================================================
FRONTEND_PORT=3000
# Local: http://localhost:3001 — production same-origin: https://your-domain.com (nginx must proxy /api/ to Nest)
NEXT_PUBLIC_API_URL=http://localhost:3001
WATCHPACK_POLLING=true

# =============================================================================
# Optional — backend on host / tooling (not passed by compose to containers)
# =============================================================================
# DIGEST_CRON=0 8 * * *
# TYPEORM_LOGGING=true
